# Configuración de Commit AI CLI
# Copia este archivo a .env — se carga automáticamente al iniciar la CLI

# API key de OpenRouter (proveedor por defecto)
# OPENROUTER_API_KEY=sk-or-v1-...

# API key de DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Proveedor por defecto (openrouter, deepseek)
# DEFAULT_PROVIDER=openrouter

# Modelo de IA por defecto
DEFAULT_MODEL=openrouter/free

# Estilo de commit por defecto (conventional, emoji, descriptive)
DEFAULT_STYLE=conventional

# Modo debug
DEBUG=false