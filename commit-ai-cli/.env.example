# Configuración de Commit AI CLI

# Token de autenticación de Puter (opcional si usas browser auth)
# PUTER_AUTH_TOKEN=your-token-here

# Modelo de IA por defecto
DEFAULT_MODEL=gpt-5.4-nano

# Estilo de commit por defecto (conventional, emoji, descriptive)
DEFAULT_STYLE=conventional

# Modo debug
DEBUG=false
